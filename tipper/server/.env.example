# Copiez en .env et adaptez (tout fonctionne sans configuration)
PORT=4000
JWT_SECRET=change-me-in-production

# Notifications push (Web Push) — générées automatiquement si vides
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@tipper.app

# Paiement Stripe (optionnel) — sans clé, le rechargement est simulé.
# Renseignez ces variables pour activer l'achat réel de Tipper Coins :
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx   # endpoint webhook : POST /api/wallet/stripe-webhook
