# Copiez ce fichier en .env et adaptez si besoin (tout fonctionne sans configuration)
PORT=4000
JWT_SECRET=change-me-in-production

# Clés VAPID pour les notifications push.
# Laissez vide : elles sont générées automatiquement au premier démarrage (server/data/vapid.json).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@tipper.app
