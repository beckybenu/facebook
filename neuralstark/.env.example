# --- NeuralStark : configuration ---
# Copiez ce fichier en « .env » et adaptez les valeurs.
# NB : le fichier .env n'est PAS committé (voir .gitignore).

# Port du serveur (défaut : 5178)
PORT=5178

# --- LLM (optionnel) ---
# Laissez vide pour rester en MODE DÉMO (réponses extractives, aucune clé requise).
# Renseignez une clé pour activer les réponses génératives via une API
# compatible OpenAI (OpenAI, DeepSeek, Groq, Ollama, LM Studio, vLLM…).
LLM_API_KEY=
# URL de base de l'API (exemples ci-dessous) :
#   OpenAI   : https://api.openai.com/v1
#   DeepSeek : https://api.deepseek.com/v1
#   Groq     : https://api.groq.com/openai/v1
#   Ollama   : http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1
# Modèle à utiliser
LLM_MODEL=gpt-4o-mini
