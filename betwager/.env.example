# Base de données (SQLite par défaut ; pour la production vous pouvez pointer
# vers un volume persistant, ex. file:/data/betwager.db)
DATABASE_URL="file:./dev.db"

# Secret de signature des sessions JWT — OBLIGATOIRE à changer en production.
# Générez-en un avec : openssl rand -hex 32
AUTH_SECRET="remplacez-moi-par-un-secret-aleatoire"
